# syntax=docker/dockerfile:1.7
# =============================================================================
# AOS Common Agent Dockerfile
#
# Shared across all agent layers. All variation is passed as build args
# from the workflow - no layer-specific logic lives here.
#
# Build args (all required, all passed by workflow):
#   PARENT_IMAGE     Full image reference without digest
#                    e.g. acraosstagingerm2srfd.azurecr.io/aos/infra
#   PARENT_DIGEST    Digest of parent image fetched live from ACR
#                    e.g. sha256:abc123...
#   LAYER_NUMBER     Numeric layer position e.g. 2
#   LAYER_NAME       Kebab-case layer name  e.g. purpose-driven-agent
#   PACKAGE_DIR      Directory name under /app/ e.g. purpose_driven_agent
#   REPO_NAME        GitHub repo name       e.g. ASISaga/purpose-driven-agent
#
# Build context (sent by workflow, always tiny):
#   compiled/<PACKAGE_DIR>/   Pre-compiled .pyc files only - no .py source
#
# The workflow compiles .py - .pyc before calling az acr build.
# This Dockerfile never sees .py source - only bytecode enters the image.
# =============================================================================

ARG PARENT_IMAGE
ARG PARENT_DIGEST

FROM ${PARENT_IMAGE}@${PARENT_DIGEST}

# -- Build-time metadata args --------------------------------------------------
ARG LAYER_NUMBER
ARG LAYER_NAME
ARG PACKAGE_DIR
ARG REPO_NAME

# -- Labels --------------------------------------------------------------------
LABEL org.opencontainers.image.vendor="ASI Saga"
LABEL org.opencontainers.image.source="https://github.com/${REPO_NAME}"
LABEL aos.network="neutral"
LABEL aos.layer="${LAYER_NUMBER}"
LABEL aos.layer.name="${LAYER_NAME}"
LABEL aos.parent.image="${PARENT_IMAGE}"
LABEL aos.parent.digest="${PARENT_DIGEST}"

WORKDIR /app

# -- Copy pre-compiled bytecode ------------------------------------------------
# compiled/<PACKAGE_DIR>/ is built by the workflow before az acr build.
# Only .pyc files are present - workflow strips .py before sending context.
COPY --chown=aosuser:aosuser compiled/${PACKAGE_DIR}/ ./${PACKAGE_DIR}/

# -- Verify: no .py source, .pyc present --------------------------------------
# PACKAGE_DIR is a build arg - use shell to expand it, not os.environ
RUN PY=$(find /app/${PACKAGE_DIR}/ -name "*.py"  2>/dev/null | wc -l) && \
    PYC=$(find /app/${PACKAGE_DIR}/ -name "*.pyc" 2>/dev/null | wc -l) && \
    echo "Layer ${LAYER_NUMBER} (${LAYER_NAME}): ${PY} .py, ${PYC} .pyc" && \
    echo "Files in /app/${PACKAGE_DIR}/:" && \
    find /app/${PACKAGE_DIR}/ -name "*.pyc" | sort && \
    [ "$PY"  -eq 0 ] || (echo "ERROR: .py source found in image" && exit 1) && \
    [ "$PYC" -gt 0 ] || (echo "ERROR: no .pyc files found - build context error" && exit 1)

# Runtime entry point: always purpose_driven_agent
# __main__.py discovers the most-derived FounderAgent (or equivalent)
# via __init_subclass__ registry and starts the FAS hosting adapter
USER aosuser
CMD python -m purpose_driven_agent
