# syntax=docker/dockerfile:1.7
# =============================================================================
# AOS Common Agent Dockerfile
#
# All compiled packages in the build context are copied into /app/.
# The build context contains compiled/<package>/ directories.
# Workflow compiles all packages before calling az acr build.
# =============================================================================

ARG PARENT_IMAGE
ARG PARENT_DIGEST

FROM ${PARENT_IMAGE}@${PARENT_DIGEST}

ARG LAYER_NUMBER
ARG LAYER_NAME
ARG PACKAGE_DIR
ARG REPO_NAME

LABEL org.opencontainers.image.vendor="ASI Saga"
LABEL org.opencontainers.image.source="https://github.com/${REPO_NAME}"
LABEL aos.network="neutral"
LABEL aos.layer="${LAYER_NUMBER}"
LABEL aos.layer.name="${LAYER_NAME}"
LABEL aos.parent.image="${PARENT_IMAGE}"
LABEL aos.parent.digest="${PARENT_DIGEST}"

WORKDIR /app

# -- Extend PYTHONPATH to include agent packages alongside infrastructure packages
# Infrastructure sets PYTHONPATH=/app/lib/python3.12/site-packages
# Agent packages live in /app/ - both paths must be present
ENV PYTHONPATH=/app:/app/lib/python3.12/site-packages

# -- Copy ALL compiled packages into /app/ ------------------------------------
# Copies entire compiled/ directory contents so all packages land at /app/<pkg>/
# This handles primary package and any extra packages (e.g. aos_mcp_servers)
# without needing to enumerate them individually in the Dockerfile.
COPY --chown=aosuser:aosuser compiled/ ./

# -- Verify primary package ----------------------------------------------------
RUN PY=$(find /app/${PACKAGE_DIR}/ -name "*.py"  2>/dev/null | wc -l) && \
    PYC=$(find /app/${PACKAGE_DIR}/ -name "*.pyc" 2>/dev/null | wc -l) && \
    echo "Layer ${LAYER_NUMBER} (${LAYER_NAME}): ${PY} .py, ${PYC} .pyc" && \
    echo "Files in /app/${PACKAGE_DIR}/:" && \
    find /app/${PACKAGE_DIR}/ -name "*.pyc" | sort && \
    [ "$PY"  -eq 0 ] || (echo "ERROR: .py source found in image" && exit 1) && \
    [ "$PYC" -gt 0 ] || (echo "ERROR: no .pyc files found - build context error" && exit 1)

USER aosuser
CMD python -m purpose_driven_agent
